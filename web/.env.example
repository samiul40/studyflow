# Email
# For Docker dev with MailHog: set BACKEND to smtp, HOST=localhost, PORT=1025, leave user/password blank
# For production: use Resend/Mailgun SMTP credentials and set EMAIL_USE_TLS=True
# EMAIL_BACKEND is not set here — settings.py auto-selects:
#   venv (DEBUG=True): console backend, emails print to the terminal
#   Docker: docker-compose.yml overrides to smtp, emails go to MailHog at localhost:8025
# For production: set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_BACKEND=
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=studyflow@example.com